# TapLoop — required
OWNER_KEY="replace_with_a_long_random_secret"

# Supabase Postgres (server-only; use service role — never expose in client bundles)
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your_service_role_key"

# Optional: not used by this app if SUPABASE_SERVICE_ROLE_KEY is set (server uses service role only)
# SUPABASE_ANON_KEY="your_anon_key"

# Optional: approximate IP location after consent (ipapi.co). Omit to skip geo lookup.
IP_GEO_PROVIDER="ipapi"
