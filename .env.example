## Database
# Render Postgres format is fine here too.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/scam_finder?schema=public"

## NextAuth
NEXTAUTH_URL="http://localhost:3000"
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET="replace_with_64+_hex_chars"

## Admin bootstrap (used by `npm run seed`)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change_this_password"

## App URL for generating public share links
NEXT_PUBLIC_APP_URL="http://localhost:3000"

## Storage
# Where uploads and PDF exports are written (local disk).
STORAGE_DIR="./data"

## Public IP geolocation lookup (optional, runs only after visitor accepts)
# Supported: ipapi
IP_GEO_PROVIDER="ipapi"

