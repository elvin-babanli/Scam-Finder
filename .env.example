## Scam Finder (minimal)
# Owner secret to view results. Keep it private.
OWNER_KEY="replace_with_a_long_random_secret"

## Storage
# Visits are appended to: ${STORAGE_DIR}/visits.jsonl
STORAGE_DIR="./data"

## Optional: enable IP geolocation lookup (runs only AFTER consent).
# Supported: ipapi
IP_GEO_PROVIDER="ipapi"

